{
  "name": "@project/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && tsc-alias -p tsconfig.json",
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@project/api-contract": "workspace:*",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "cross-env": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.23.1"
  }
}
